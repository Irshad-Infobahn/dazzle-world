---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout
    title="Dazzle World General Trading LLC – We Trade You Benefit"
    description="Authorized distributor of polymers, resins, branded innerwear garments, perfumes, and industrial solutions across GCC, Middle East & Africa."
>
    <!-- Page Header Start !-->
    <div class="page-breadcrumb-area">
        <div class="page-overlay"></div>
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div
                        class="te-breadcrumb-wrapper wow animate__animated animate__slideInDown animate__slow"
                    >
                        <div class="te-page-heading">
                            <h3 class="te-page-title">
                                Standard Products & Industrial Solutions
                                Division
                            </h3>
                        </div>
                        <div class="te-breadcrumb-list">
                            <ul>
                                <li><a href={`${base}/`}>Home</a></li>
                                <li class="active">
                                    Standard Products & Industrial Solutions
                                    Division
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Page Header End !-->
    <!-- Project Page Start -->
    <div class="project-page-wrapper">
        <div class="container">
            <ul
                class="portfolio-btn-lis wow animate__animated animate__fadeInLeft animate__slow"
            >
                <li class="portfolio-btn active" data-filter="*">All</li>
                <li class="portfolio-btn" data-filter=".mould">
                    Mould Release Agents
                </li>
                <li class="portfolio-btn" data-filter=".ink">
                    Printing Industrial Inks
                </li>
                <li class="portfolio-btn" data-filter=".disk">
                    Grinding Disks
                </li>
                <li class="portfolio-btn" data-filter=".screw">
                    Screw & Barrel Assemblies
                </li>
                <li class="portfolio-btn" data-filter=".electronic">
                    Electronic Spare Parts
                </li>
                <li class="portfolio-btn" data-filter=".plstic">
                    Plastic Processing Consumables
                </li>
            </ul>
            <div class="row gy-5">
                <div class="col-12">
                    <div class="portfolio-gallery-wrapper">
                        <div class="portfolio-column-in-three">
                            <div
                                class="portfolio-item mould wow animate__animated animate__fadeInUp animate__slow"
                            >
                                <div class="portfolio-img">
                                    <img
                                        src={`${base}/images/products/Mould-Release-Agent.jpg`}
                                        alt="image"
                                    />
                                    <div class="bottom-fade"></div>
                                </div>
                                <div class="content-wrapper">
                                    <div class="content">
                                        <span class="sub-title"
                                            >Standard Products & Industrial
                                            Solutions</span
                                        >
                                        <h3 class="title">
                                            Mould Release Agent
                                        </h3>
                                    </div>
                                </div>
                            </div>
                            <div
                                class="portfolio-item ink wow animate__animated animate__fadeInUp animate__slow"
                            >
                                <div class="portfolio-img">
                                    <img
                                        src={`${base}/images/products/Printing-Industrial-Inks.jpg`}
                                        alt="image"
                                    />
                                    <div class="bottom-fade"></div>
                                </div>
                                <div class="content-wrapper">
                                    <div class="content">
                                        <span class="sub-title"
                                            >Standard Products & Industrial
                                            Solutions</span
                                        >
                                        <h3 class="title">
                                            Printing Industrial Inks
                                        </h3>
                                    </div>
                                </div>
                            </div>
                            <div
                                class="portfolio-item disk wow animate__animated animate__fadeInUp animate__slow"
                            >
                                <div class="portfolio-img">
                                    <img
                                        src={`${base}/images/products/Griding-Disks.jpg`}
                                        alt="image"
                                    />
                                    <div class="bottom-fade"></div>
                                </div>
                                <div class="content-wrapper">
                                    <div class="content">
                                        <span class="sub-title"
                                            >Standard Products & Industrial
                                            Solutions</span
                                        >
                                        <h3 class="title">Griding Disks</h3>
                                    </div>
                                </div>
                            </div>
                            <div
                                class="portfolio-item screw wow animate__animated animate__fadeInUp animate__slow"
                            >
                                <div class="portfolio-img">
                                    <img
                                        src={`${base}/images/products/Screw-and-Barrel.jpg`}
                                        alt="image"
                                    />
                                    <div class="bottom-fade"></div>
                                </div>
                                <div class="content-wrapper">
                                    <div class="content">
                                        <span class="sub-title"
                                            >Standard Products & Industrial
                                            Solutions</span
                                        >
                                        <h3 class="title">
                                            Screw & Barrel Assemblies
                                        </h3>
                                    </div>
                                </div>
                            </div>
                            <div
                                class="portfolio-item electronic wow animate__animated animate__fadeInUp animate__slow"
                            >
                                <div class="portfolio-img">
                                    <img
                                        src={`${base}/images/products/Electronic-Spare-Parts.jpg`}
                                        alt="image"
                                    />
                                    <div class="bottom-fade"></div>
                                </div>
                                <div class="content-wrapper">
                                    <div class="content">
                                        <span class="sub-title"
                                            >Standard Products & Industrial
                                            Solutions</span
                                        >
                                        <h3 class="title">
                                            Electronic Spare Parts
                                        </h3>
                                    </div>
                                </div>
                            </div>
                            <div
                                class="portfolio-item plstic wow animate__animated animate__fadeInUp animate__slow"
                            >
                                <div class="portfolio-img">
                                    <img
                                        src={`${base}/images/products/Plastic-Processing-Consumables.jpg`}
                                        alt="image"
                                    />
                                    <div class="bottom-fade"></div>
                                </div>
                                <div class="content-wrapper">
                                    <div class="content">
                                        <span class="sub-title"
                                            >Standard Products & Industrial
                                            Solutions</span
                                        >
                                        <h3 class="title">
                                            Plastic Processing Consumables
                                        </h3>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Project Page End -->

    <script>
        // Filter buttons
        const filterBtns = document.querySelectorAll(".portfolio-btn");
        const items = document.querySelectorAll(".portfolio-item");

        filterBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                filterBtns.forEach((b) => b.classList.remove("active"));
                btn.classList.add("active");

                const filter = btn.getAttribute("data-filter");

                items.forEach((item) => {
                    const el = item as HTMLElement;
                    if (
                        filter === "*" ||
                        (filter && item.classList.contains(filter.slice(1)))
                    ) {
                        el.style.display = "block";
                        el.classList.add(
                            "animate__animated",
                            "animate__fadeInUp",
                        );
                    } else {
                        el.style.display = "none";
                    }
                });
            });
        });
    </script>
</Layout>
