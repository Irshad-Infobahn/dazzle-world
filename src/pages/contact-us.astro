---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout
    title="Dazzle World General Trading LLC – We Trade You Benefit"
    description="Authorized distributor of polymers, resins, branded innerwear garments, perfumes, and industrial solutions across GCC, Middle East & Africa."
>
    <!-- Page Header Start !-->
    <div class="page-breadcrumb-area">
        <div class="page-overlay"></div>
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div
                        class="te-breadcrumb-wrapper wow animate__animated animate__slideInDown animate__slow"
                    >
                        <div class="te-page-heading">
                            <h3 class="te-page-title">Contact Us</h3>
                        </div>
                        <div class="te-breadcrumb-list">
                            <ul>
                                <li><a href={`${base}/`}>Home</a></li>
                                <li class="active">Contact Us</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Page Header End !-->
    <!-- Contact Form Section Start -->
    <div class="contact-form-area">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <!-- Contact Info Section Start !-->
                    <div class="te-contact-info-wrapper">
                        <div
                            class="te-contact-info wow animate__animated animate__fadeInUp animate__fast"
                        >
                            <div class="single-contact-info">
                                <div class="contact-info-inner">
                                    <div class="title-wrapper">
                                        <h3 class="title">Address</h3>
                                    </div>
                                    <div class="content-wrapper">
                                        <p>
                                            P.O. Box 34139 , 3<sup>rd</sup> - 76 6B
                                            Street, <br /> Al Qouz Ind.3<sup
                                                >rd</sup
                                            > - Al Quoz, Dubai, United Arab Emirates.
                                        </p>
                                    </div>
                                </div>
                                <div class="contact-info-inner">
                                    <div class="title-wrapper">
                                        <h3 class="title">Email Address</h3>
                                    </div>
                                    <div class="content-wrapper">
                                        <p>management@dazzle-world.com</p>
                                        <p>sales@dazzle-world.com</p>
                                    </div>
                                </div>
                            </div>
                            <div class="single-contact-info">
                                <div class="contact-info-inner">
                                    <div class="title-wrapper">
                                        <h3 class="title">Phone Numbers</h3>
                                    </div>
                                    <div class="content-wrapper">
                                        <p>
                                            +971 56 262 7834 <br /> +971 50 693 3757
                                        </p>
                                    </div>
                                </div>
                                <div class="contact-info-inner">
                                    <div class="title-wrapper">
                                        <h3 class="title">Social media</h3>
                                    </div>
                                    <div class="content-wrapper">
                                        <div class="social-link">
                                            <a href="#"
                                                ><i
                                                    class="fa-brands fa-facebook-f"
                                                ></i></a
                                            >
                                            <a href="#"
                                                ><i class="fa-brands fa-twitter"
                                                ></i></a
                                            >
                                            <a href="#"
                                                ><i
                                                    class="fa-brands fa-linkedin-in"
                                                ></i></a
                                            >
                                            <a href="#"
                                                ><i class="fa-brands fa-youtube"
                                                ></i></a
                                            >
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Contact Info Section End -->
                </div>
                <div class="col-lg-12">
                    <!-- Comment Form Start -->
                    <div
                        class="comment-respond mt-0 wow animate__animated animate__fadeInUp animate__slow"
                    >
                        <h4 class="title">Get in touch with us</h4>
                        <p class="mb-4">
                            For inquiries, partnerships, or distributorship
                            opportunities, please contact us.
                        </p>
                        <form class="te-comment-form">
                            <div class="row gx-4">
                                <div class="col-xl-12">
                                    <div class="te-contacts-name">
                                        <input
                                            name="name"
                                            type="text"
                                            placeholder="Your Name"
                                        />
                                    </div>
                                </div>
                                <div class="col-xl-6">
                                    <div class="te-contacts-email">
                                        <input
                                            name="email"
                                            type="email"
                                            placeholder="Your Email*"
                                        />
                                    </div>
                                </div>
                                <div class="col-xl-6">
                                    <div class="te-contacts-name">
                                        <input
                                            name="phone"
                                            type="text"
                                            placeholder="Your Phone"
                                        />
                                    </div>
                                </div>
                                <div class="col-xl-12">
                                    <div class="te-contacts-message">
                                        <textarea
                                            name="message"
                                            cols="20"
                                            rows="3"
                                            placeholder="Write your Message here"
                                        ></textarea>
                                    </div>
                                </div>
                                <div class="col-12 text-center">
                                    <button
                                        class="te-theme-btn blue-btn rounded-1"
                                        type="submit">Send a messege</button
                                    >
                                </div>
                            </div>
                        </form>
                    </div>
                    <!-- Comment Form End -->
                </div>
            </div>
        </div>
    </div>
    <!-- Contact Form Section End -->

    <!-- Map start -->
    <div class="contact-map-area">
        <div class="te-map-widget">
            <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3612.393679990403!2d55.20689237394528!3d25.12237793472985!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3e5f6bc6abf907a5%3A0x2c27ee334ca06650!2sDazzle%20World%20General%20Trading%20L.L.C!5e0!3m2!1sen!2sae!4v1770792788534!5m2!1sen!2sae"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
    </div>
    <!-- Map end -->
    <!--- Start Footer !-->
</Layout>
