---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout
    title="Dazzle World General Trading LLC – We Trade You Benefit"
    description="Authorized distributor of polymers, resins, branded innerwear garments, perfumes, and industrial solutions across GCC, Middle East & Africa."
>
    <!-- Page Header Start !-->
    <div class="page-breadcrumb-area">
        <div class="page-overlay"></div>
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div
                        class="te-breadcrumb-wrapper wow animate__animated animate__slideInDown animate__slow"
                    >
                        <div class="te-page-heading">
                            <h3 class="te-page-title">Perfumes Division</h3>
                        </div>
                        <div class="te-breadcrumb-list">
                            <ul>
                                <li><a href={`${base}/`}>Home</a></li>
                                <li class="active">Perfumes Division</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Page Header End !-->
    <!-- Project Page Start -->
    <div class="project-page-wrapper">
        <div class="container">
            <p>
                <span>At Dazzle World,</span> we specialize in the supply of high-quality
                international and oriental perfumes, offering a unique collection
                of traditional and modern fragrances inspired by the rich heritage
                of the Middle East alongside renowned global scent profiles. Our products
                are crafted with premium ingredients to ensure long-lasting, distinctive
                fragrances that meet international standards.
            </p>
            <p class="mb-5">
                With strong export capabilities, we proudly serve clients across
                USA and Europe, building trusted partnerships through quality,
                consistency, and competitive pricing.
            </p>
            <ul
                class="portfolio-btn-lis wow animate__animated animate__fadeInLeft animate__slow"
            >
                <li class="portfolio-btn active" data-filter="*">All</li>
                <li class="portfolio-btn" data-filter=".orient">
                    Oriental Perfumes
                </li>
                <li class="portfolio-btn" data-filter=".international">
                    International Branded Perfumes
                </li>
            </ul>
            <div class="row gy-5">
                <div class="col-12">
                    <div class="portfolio-gallery-wrapper">
                        <div class="portfolio-column-in-three">
                            <div
                                class="portfolio-item orient wow animate__animated animate__fadeInUp animate__slow"
                            >
                                <div class="portfolio-img">
                                    <img
                                        src={`${base}/images/perfumes/perfume-1.jpg`}
                                        alt="image"
                                    />
                                    <div class="bottom-fade"></div>
                                </div>
                                <div class="content-wrapper">
                                    <div class="content">
                                        <span class="sub-title"
                                            >Oriental Perfumes</span
                                        >
                                        <button
                                            class="btn btn-warning enquiry-btn"
                                            data-bs-toggle="modal"
                                            data-bs-target="#enquiryModal"
                                            data-product="Oriental Perfume"
                                            data-image={`${base}/images/perfumes/perfume-1.jpg`}
                                        >
                                            Enquire Now
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div
                                class="portfolio-item international wow animate__animated animate__fadeInUp animate__slow"
                            >
                                <div class="portfolio-img">
                                    <img
                                        src={`${base}/images/perfumes/perfume-4.jpg`}
                                        alt="image"
                                    />
                                    <div class="bottom-fade"></div>
                                </div>
                                <div class="content-wrapper">
                                    <div class="content">
                                        <span class="sub-title"
                                            >International Perfumes</span
                                        >
                                        <button
                                            class="btn btn-warning enquiry-btn"
                                            data-bs-toggle="modal"
                                            data-bs-target="#enquiryModal"
                                            data-product="International Perfume"
                                            data-image={`${base}/images/perfumes/perfume-4.jpg`}
                                        >
                                            Enquire Now
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div
                                class="portfolio-item orient wow animate__animated animate__fadeInUp animate__slow"
                            >
                                <div class="portfolio-img">
                                    <img
                                        src={`${base}/images/perfumes/perfume-2.jpg`}
                                        alt="image"
                                    />
                                    <div class="bottom-fade"></div>
                                </div>
                                <div class="content-wrapper">
                                    <div class="content">
                                        <span class="sub-title"
                                            >Oriental Perfumes</span
                                        >
                                        <button
                                            class="btn btn-warning enquiry-btn"
                                            data-bs-toggle="modal"
                                            data-bs-target="#enquiryModal"
                                            data-product="Oriental Perfume"
                                            data-image={`${base}/images/perfumes/perfume-2.jpg`}
                                        >
                                            Enquire Now
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div
                                class="portfolio-item international wow animate__animated animate__fadeInUp animate__slow"
                            >
                                <div class="portfolio-img">
                                    <img
                                        src={`${base}/images/perfumes/perfume-5.jpg`}
                                        alt="image"
                                    />
                                    <div class="bottom-fade"></div>
                                </div>
                                <div class="content-wrapper">
                                    <div class="content">
                                        <span class="sub-title"
                                            >International Perfumes</span
                                        >
                                        <button
                                            class="btn btn-warning enquiry-btn"
                                            data-bs-toggle="modal"
                                            data-bs-target="#enquiryModal"
                                            data-product="International Perfume"
                                            data-image={`${base}/images/perfumes/perfume-5.jpg`}
                                        >
                                            Enquire Now
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div
                                class="portfolio-item orient wow animate__animated animate__fadeInUp animate__slow"
                            >
                                <div class="portfolio-img">
                                    <img
                                        src={`${base}/images/perfumes/perfume-3.jpg`}
                                        alt="image"
                                    />
                                    <div class="bottom-fade"></div>
                                </div>
                                <div class="content-wrapper">
                                    <div class="content">
                                        <span class="sub-title"
                                            >Oriental Perfumes</span
                                        >
                                        <button
                                            class="btn btn-warning enquiry-btn"
                                            data-bs-toggle="modal"
                                            data-bs-target="#enquiryModal"
                                            data-product="Oriental Perfume"
                                            data-image={`${base}/images/perfumes/perfume-3.jpg`}
                                        >
                                            Enquire Now
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div
                                class="portfolio-item international wow animate__animated animate__fadeInUp animate__slow"
                            >
                                <div class="portfolio-img">
                                    <img
                                        src={`${base}/images/perfumes/perfume-6.jpg`}
                                        alt="image"
                                    />
                                    <div class="bottom-fade"></div>
                                </div>
                                <div class="content-wrapper">
                                    <div class="content">
                                        <span class="sub-title"
                                            >International Perfumes</span
                                        >
                                        <button
                                            class="btn btn-warning enquiry-btn"
                                            data-bs-toggle="modal"
                                            data-bs-target="#enquiryModal"
                                            data-product="International Perfume"
                                            data-image={`${base}/images/perfumes/perfume-6.jpg`}
                                        >
                                            Enquire Now
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Project Page End -->

    <div class="modal fade" id="enquiryModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content eq-modal-content">
                <div class="eq-modal-header">
                    <div class="eq-modal-header-text">
                        <p>Product Enquiry</p>
                        <h5 id="modalProductTitle">Product Name</h5>
                    </div>
                    <button
                        type="button"
                        class="eq-modal-close"
                        data-bs-dismiss="modal">✕</button
                    >
                </div>

                <div class="modal-body eq-modal-body">
                    <div class="eq-modal-grid">
                        <div class="eq-modal-image-panel">
                            <div class="eq-product-image-wrapper">
                                <img id="productImage" src="" alt="Product" />
                            </div>
                            <span id="productCategory" class="eq-product-badge"
                                >Category</span
                            >
                        </div>

                        <div class="eq-modal-form-panel">
                            <form id="enquiryForm" class="eq-form">
                                <input
                                    type="hidden"
                                    name="product"
                                    id="productDropdown"
                                />

                                <div class="eq-form-row">
                                    <div class="eq-field">
                                        <label class="eq-label">Your Name</label
                                        >
                                        <input
                                            type="text"
                                            name="name"
                                            placeholder="John Smith"
                                            required
                                            class="eq-input"
                                        />
                                    </div>
                                    <div class="eq-field">
                                        <label class="eq-label">Phone</label>
                                        <input
                                            type="text"
                                            name="phone"
                                            placeholder="+971 50 000 0000"
                                            class="eq-input"
                                        />
                                    </div>
                                </div>

                                <div class="eq-field">
                                    <label class="eq-label">Email</label>
                                    <input
                                        type="email"
                                        name="email"
                                        placeholder="john@company.com"
                                        required
                                        class="eq-input"
                                    />
                                </div>

                                <div class="eq-field">
                                    <label class="eq-label">Message</label>
                                    <textarea
                                        name="message"
                                        placeholder="Quantity required, delivery location, etc."
                                        rows="3"
                                        class="eq-textarea"></textarea>
                                </div>

                                <button type="submit" class="eq-submit-btn">
                                    Send Enquiry →
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const filterBtns = document.querySelectorAll(".portfolio-btn");
        const items = document.querySelectorAll(".portfolio-item");

        filterBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                filterBtns.forEach((b) => b.classList.remove("active"));
                btn.classList.add("active");

                const filter = btn.getAttribute("data-filter");

                items.forEach((item) => {
                    const el = item as HTMLElement;
                    if (
                        filter === "*" ||
                        (filter && item.classList.contains(filter.slice(1)))
                    ) {
                        el.style.display = "block";
                        el.classList.add(
                            "animate__animated",
                            "animate__fadeInUp",
                        );
                    } else {
                        el.style.display = "none";
                    }
                });
            });
        });

        document.querySelectorAll(".enquiry-btn").forEach((btn) => {
            btn.addEventListener("click", (e) => {
                const target = e.currentTarget as HTMLElement;
                const product = target.dataset.product;
                const image = target.dataset.image;
                const category =
                    target.closest(".content")?.querySelector(".sub-title")
                        ?.textContent ?? "";

                const modalTitle = document.getElementById("modalProductTitle");
                const dropdown = document.getElementById(
                    "productDropdown",
                ) as HTMLInputElement | null;
                const productImage = document.getElementById(
                    "productImage",
                ) as HTMLImageElement | null;
                const productCategory =
                    document.getElementById("productCategory");

                if (modalTitle) modalTitle.textContent = product ?? "";
                if (dropdown) dropdown.value = product ?? "";
                if (productImage) productImage.src = image ?? "";
                if (productCategory) productCategory.textContent = category;
            });
        });
    </script>
</Layout>
