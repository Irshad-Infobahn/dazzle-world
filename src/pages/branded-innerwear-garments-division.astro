---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout
  title="Dazzle World General Trading LLC – We Trade You Benefit"
  description="Authorized distributor of polymers, resins, branded innerwear garments, perfumes, and industrial solutions across GCC, Middle East & Africa."
>

<!-- Page Header Start !-->
    <div class="page-breadcrumb-area">
        <div class="page-overlay"></div>
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="te-breadcrumb-wrapper wow animate__animated animate__slideInDown animate__slow">
                        <div class="te-page-heading">
                            <h3 class="te-page-title">Branded Innerwear Garments Division</h3>
                        </div>
                        <div class="te-breadcrumb-list">
                            <ul>
                                <li><a href={`${base}/`}>Home</a></li>
                                <li class="active">Branded Innerwear Garments Division</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Page Header End !--> 
    
    <!-- Project Page Start -->
    <div class="project-page-wrapper">
        <div class="container">
            <div class="row gy-5">
                <div class="col-12 col-md-3">
                    <a href={`${base}/images/innerwear/Macro_Catalog.pdf`} target="_blank">
                        <div class="branded-item wow animate__animated animate__fadeInUp animate__faster">
                            <div class="branded-image">
                                <img src={`${base}/images/partner/macro.png`} alt="image">
                                <div class="branded-overlay">
                                    <i class="fas fa-eye"></i> View Catalogue
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-12 col-md-3">
                    <a href={`${base}/images/innerwear/Macroman-Product-Catalougue.pdf`} target="_blank">
                        <div class="branded-item wow animate__animated animate__fadeInUp animate__fast">
                            <div class="branded-image">
                                <img src={`${base}/images/partner/macro-men.png`} alt="image">
                                <div class="branded-overlay">
                                    <i class="fas fa-eye"></i> View Catalogue
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-12 col-md-3">
                    <a href={`${base}/images/innerwear/Product-Catalogue-Rupa.pdf`} target="_blank">
                        <div class="branded-item wow animate__animated animate__fadeInUp animate__slow">
                            <div class="branded-image">
                                <img src={`${base}/images/partner/rupa.png`} alt="image">
                                <div class="branded-overlay">
                                    <i class="fas fa-eye"></i> View Catalogue
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-12 col-md-3">
                    <a href={`${base}/images/innerwear/Product-Catalogue-Softline-Wamiqa-Outerwear.pdf`} target="_blank">
                        <div class="branded-item wow animate__animated animate__fadeInUp animate__slower">
                            <div class="branded-image">
                                <img src={`${base}/images/partner/match-it-by-softline.png`} alt="image">
                                <div class="branded-overlay">
                                    <i class="fas fa-eye"></i> View Catalogue
                                </div>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-12 col-md-3">
                    <a href={`${base}/images/innerwear/Product-Catalogue-Softline-Lingerie.pdf`} target="_blank">
                        <div class="branded-item wow animate__animated animate__fadeInUp animate__slow">
                            <div class="branded-image">
                                <img src={`${base}/images/partner/softline.png`} alt="image">
                                <div class="branded-overlay">
                                    <i class="fas fa-eye"></i> View Catalogue
                                </div>
                            </div>
                        </div>
                    </a>
                </div>


                <div class="col-12 col-md-3 col">
                    <a href={`${base}/images/innerwear/Macrowomen-Product-Catalogue.pdf`} target="_blank">
                        <div class="branded-item wow animate__animated animate__fadeInUp animate__slow">
                            <div class="branded-image">
                                <img src={`${base}/images/partner/macro-women.png`} alt="image">
                                <div class="branded-overlay">
                                    <i class="fas fa-eye"></i> View Catalogue
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-12 col-md-3">
                    <a href={`${base}/images/innerwear/MW-Socks-Product-Catalogue.pdf`} target="_blank">
                        <div class="branded-item wow animate__animated animate__fadeInUp animate__slow">
                            <div class="branded-image">
                                <img src={`${base}/images/partner/macro-world.png`} alt="image">
                                <div class="branded-overlay">
                                    <i class="fas fa-eye"></i> View Catalogue
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <!-- Project Page End -->

</Layout>