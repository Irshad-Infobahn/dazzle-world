---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout
	title="Dazzle World General Trading LLC – We Trade You Benefit"
	description="Authorized distributor of polymers, resins, branded innerwear garments, perfumes, and industrial solutions across GCC, Middle East & Africa."
>
	<!-- ==================== BANNER ==================== -->
	<div class="banner-area style-1">
		<div class="container">
			<div class="row gy-5 banner-content-row">
				<div class="col-lg-8">
					<div class="banner-wrapper">
						<div class="banner-carousel">
							<div class="banner-image">
								<img
									class="tilt-active"
									src={`${base}/images/banner/image-1.jpg`}
									alt="Polymer & Resin Division"
								/>
								<div class="slide-text">
									Polymer &amp; Resin Division
								</div>
							</div>
							<div class="banner-image">
								<img
									class="tilt-active"
									src={`${base}/images/banner/image-2.jpg`}
									alt="Branded Innerwear Garments Division"
								/>
								<div class="slide-text">
									Branded Innerwear<br />Garments Division
								</div>
							</div>
							<div class="banner-image">
								<img
									class="tilt-active"
									src={`${base}/images/banner/image-3.jpg`}
									alt="Perfumes Division"
								/>
								<div class="slide-text">Perfumes Division</div>
							</div>
							<div class="banner-image">
								<img
									class="tilt-active"
									src={`${base}/images/banner/image-4.jpg`}
									alt="Standard Products & Industrial Solutions Division"
								/>
								<div class="slide-text">
									Standard Products &amp; Industrial<br
									/>Solutions Division
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="col-lg-4 align-self-center">
					<div class="banner-info-card style-1">
						<div
							class="content-wrapper mb-20 animate__animated animate__slideInDown animate__slow"
						>
							<h3 class="my-h3">
								Global Trading Excellence Across Industries
								&amp; Markets
							</h3>
						</div>
						<div
							class="message-feature-card animate__animated animate__slideInUp animate__slow"
						>
							<p>
								Authorized distributor of multinational polymer
								producers, distributor of branded innerwear
								garments, and trusted supplier of premium
								oriental and international perfumes and
								industrial solutions across the Middle East,
								Africa, and global markets.
							</p>
						</div>
						<div
							class="btn-wrapper animate__animated animate__slideInRight animate__slow"
						>
							<a
								href={`${base}/company-profile`}
								class="te-theme-btn blue-btn"
							>
								Read More <i class="fa fa-solid fa-arrow-right"
								></i>
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- ==================== /BANNER ==================== -->

	<!-- ==================== OUR DIVISIONS ==================== -->
	<div class="latest-service-area style-1">
		<div class="container">
			<div class="row">
				<div
					class="col-12 wow animate__animated animate__slideInDown animate__slow"
				>
					<div
						class="te-section-title justify-content-center text-center"
					>
						<div class="te-section-content">
							<div class="short-title-wrapper">
								<span class="short-title">What We Provide</span>
							</div>
							<h2 class="title">Our Divisions</h2>
						</div>
					</div>
				</div>
			</div>

			<div class="row">
				<div class="col-12">
					<div class="latest-service-wrapper">
						<!-- Polymer & Resin -->
						<div
							class="latest-service-card wow animate__animated animate__fadeInUp animate__faster"
						>
							<div class="circle-drop-shadow"></div>
							<div class="content-wrapper">
								<div
									class="icon wow animate__animated animate__flipInX animate__slow"
								>
									<img
										src={`${base}/images/icon/service-icon/polymer-resin.jpg`}
										alt="Polymer & Resin"
										style="border-radius:100%;padding:5px;"
									/>
								</div>
								<div class="title-wrapper">
									<h3 class="title">
										<a
											href={`${base}/polymer-and-resin-division`}
											>Polymer &amp; Resin Division</a>
									</h3>
								</div>
								<div class="content">
									<p class="text-justify">
										Delivering high-quality polymers and
										resins sourced from leading
										international manufacturers, supporting
										diverse industrial applications with
										reliable supply, technical expertise,
										and consistent quality across regional
										and global markets.
									</p>
								</div>
							</div>
							<a
								href={`${base}/polymer-and-resin-division`}
								class="btn-wrapper"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="67"
									height="16"
									viewBox="0 0 67 16"
									fill="none"
								>
									<path
										d="M66.7071 8.70711C67.0976 8.31658 67.0976 7.68342 66.7071 7.29289L60.3431 0.928932C59.9526 0.538408 59.3195 0.538408 58.9289 0.928932C58.5384 1.31946 58.5384 1.95262 58.9289 2.34315L64.5858 8L58.9289 13.6569C58.5384 14.0474 58.5384 14.6805 58.9289 15.0711C59.3195 15.4616 59.9526 15.4616 60.3431 15.0711L66.7071 8.70711ZM0 9H66V7H0L0 9Z"
										fill="#4e336a"></path>
								</svg>
							</a>
						</div>

						<!-- Branded Innerwear -->
						<div
							class="latest-service-card wow animate__animated animate__fadeInUp animate__fast"
						>
							<div class="circle-drop-shadow"></div>
							<div class="content-wrapper">
								<div
									class="icon wow animate__animated animate__flipInX animate__slow"
								>
									<img
										src={`${base}/images/icon/service-icon/innerwear.jpg`}
										alt="Branded Innerwear Garments"
										style="border-radius:100%;padding:5px;"
									/>
								</div>
								<div class="title-wrapper">
									<h3 class="title">
										<a
											href={`${base}/branded-innerwear-garments-division`}
											>Branded Innerwear Garments Division</a>
									</h3>
								</div>
								<div class="content">
									<p class="text-justify">
										Sole distributor of premium branded
										innerwear garments, offering trusted
										quality, wide market reach, and strong
										distribution capabilities across the
										Middle East and Africa, backed by
										established brand partnerships.
									</p>
								</div>
							</div>
							<a
								href={`${base}/branded-innerwear-garments-division`}
								class="btn-wrapper"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="67"
									height="16"
									viewBox="0 0 67 16"
									fill="none"
								>
									<path
										d="M66.7071 8.70711C67.0976 8.31658 67.0976 7.68342 66.7071 7.29289L60.3431 0.928932C59.9526 0.538408 59.3195 0.538408 58.9289 0.928932C58.5384 1.31946 58.5384 1.95262 58.9289 2.34315L64.5858 8L58.9289 13.6569C58.5384 14.0474 58.5384 14.6805 58.9289 15.0711C59.3195 15.4616 59.9526 15.4616 60.3431 15.0711L66.7071 8.70711ZM0 9H66V7H0L0 9Z"
										fill="#4e336a"></path>
								</svg>
							</a>
						</div>

						<!-- Perfumes -->
						<div
							class="latest-service-card wow animate__animated animate__fadeInUp animate__slow"
						>
							<div class="circle-drop-shadow"></div>
							<div class="content-wrapper">
								<div
									class="icon wow animate__animated animate__flipInX animate__slow"
								>
									<img
										src={`${base}/images/icon/service-icon/perfume.jpg`}
										alt="Perfumes Division"
										style="border-radius:100%;padding:5px;"
									/>
								</div>
								<div class="title-wrapper">
									<h3 class="title">
										<a href={`${base}/perfumes-division`}
											>Perfumes Division</a>
									</h3>
								</div>
								<div class="content">
									<p class="text-justify">
										At Dazzle World, we specialize in the
										supply of high-quality international and
										oriental perfumes, offering a unique
										collection of traditional and modern
										fragrances inspired by the rich heritage
										of the Middle East alongside renowned
										global scent profiles. Our products are
										crafted with premium ingredients to
										ensure long-lasting, distinctive
										fragrances that meet international
										standards.
									</p>
								</div>
							</div>
							<a
								href={`${base}/perfumes-division`}
								class="btn-wrapper"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="67"
									height="16"
									viewBox="0 0 67 16"
									fill="none"
								>
									<path
										d="M66.7071 8.70711C67.0976 8.31658 67.0976 7.68342 66.7071 7.29289L60.3431 0.928932C59.9526 0.538408 59.3195 0.538408 58.9289 0.928932C58.5384 1.31946 58.5384 1.95262 58.9289 2.34315L64.5858 8L58.9289 13.6569C58.5384 14.0474 58.5384 14.6805 58.9289 15.0711C59.3195 15.4616 59.9526 15.4616 60.3431 15.0711L66.7071 8.70711ZM0 9H66V7H0L0 9Z"
										fill="#4e336a"></path>
								</svg>
							</a>
						</div>

						<!-- Industrial Solutions -->
						<div
							class="latest-service-card wow animate__animated animate__fadeInUp animate__slower"
						>
							<div class="circle-drop-shadow"></div>
							<div class="content-wrapper">
								<div
									class="icon wow animate__animated animate__flipInX animate__slow"
								>
									<img
										src={`${base}/images/icon/service-icon/industrial-solutions.jpg`}
										alt="Standard Products & Industrial Solutions"
										style="border-radius:100%;padding:5px;"
									/>
								</div>
								<div class="title-wrapper">
									<h3 class="title">
										<a
											href={`${base}/standard-products-and-industrial-solutions-division`}
											>Standard Products &amp; Industrial
											Solutions Division</a>
									</h3>
								</div>
								<div class="content">
									<p class="text-justify">
										Providing a comprehensive range of
										industrial consumables and equipment for
										plastic processing and manufacturing
										industries, ensuring operational
										efficiency, durability, and dependable
										after-sales support.
									</p>
								</div>
							</div>
							<a
								href={`${base}/standard-products-and-industrial-solutions-division`}
								class="btn-wrapper"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="67"
									height="16"
									viewBox="0 0 67 16"
									fill="none"
								>
									<path
										d="M66.7071 8.70711C67.0976 8.31658 67.0976 7.68342 66.7071 7.29289L60.3431 0.928932C59.9526 0.538408 59.3195 0.538408 58.9289 0.928932C58.5384 1.31946 58.5384 1.95262 58.9289 2.34315L64.5858 8L58.9289 13.6569C58.5384 14.0474 58.5384 14.6805 58.9289 15.0711C59.3195 15.4616 59.9526 15.4616 60.3431 15.0711L66.7071 8.70711ZM0 9H66V7H0L0 9Z"
										fill="#4e336a"></path>
								</svg>
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- ==================== /OUR DIVISIONS ==================== -->

	<!-- ==================== ABOUT ==================== -->
	<div class="about-feature-area">
		<div class="circle-drop-shadow"></div>
		<div class="container">
			<div class="row gy-4 align-items-center">
				<div
					class="col-lg-6 order-2 order-lg-1 wow animate__animated animate__slideInLeft animate__slow"
				>
					<div class="about-us-card">
						<div class="te-section-title">
							<div class="te-section-content">
								<div class="short-title-wrapper">
									<span class="short-title">About Us</span>
								</div>
								<h2 class="title">We Trade You Benefit</h2>
								<p class="text-justify">
									<strong
										>M/s Dazzle World General Trading LLC</strong
									> is a well-established business conglomerate
									established in 2013 with its <strong
										>head office in Dubai</strong
									>
									and <strong
										>branch offices in Ajman (UAE) and Doha
										(Qatar)</strong
									>. The company is managed by highly trained
									professionals specialising in supply chain
									management, international trading, and
									product distribution.
								</p>
								<p>Dazzle World operates as:</p>
							</div>
						</div>
						<div class="te-list-item-wrapper">
							<div class="te-list-item">
								<div class="icon">
									<i class="fas fa-check-circle"></i>
								</div>
								<span class="text"
									>Authorized distributor of international
									polymer producers.</span
								>
							</div>
							<div class="te-list-item">
								<div class="icon">
									<i class="fas fa-check-circle"></i>
								</div>
								<span class="text"
									>Sole Distributor of Rupa &amp; Company Ltd
									innerwear garments in the GCC &amp; Africa.</span
								>
							</div>
							<div class="te-list-item">
								<div class="icon">
									<i class="fas fa-check-circle"></i>
								</div>
								<span class="text"
									>Distributor of industrial products and
									consumables for plastic processing
									industries.</span
								>
							</div>
						</div>
					</div>
				</div>
				<div
					class="col-lg-6 col-xl-5 offset-xl-1 order-1 order-lg-2 wow animate__animated animate__zoomIn animate__slow"
				>
					<div class="image-card">
						<img
							class="tilt-animate"
							src={`${base}/images/about/about-card-1.jpg`}
							alt="About Dazzle World"
						/>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- ==================== /ABOUT ==================== -->

	<!-- ==================== PHILOSOPHY ==================== -->
	<div class="feature-area style-1">
		<div class="circle-drop-shadow"></div>
		<div class="container">
			<div class="row">
				<div
					class="col-12 wow animate__animated animate__slideInDown animate__slow"
				>
					<div
						class="te-section-title justify-content-center text-center"
					>
						<div class="te-section-content">
							<div class="short-title-wrapper">
								<span class="short-title">Our Philosophy</span>
							</div>
							<h2 class="title">We Trade You Benefit</h2>
						</div>
					</div>
				</div>
			</div>
			<div class="row gy-4">
				<div
					class="col-md-12 col-lg-12 feature-card wow animate__animated animate__fadeInUp animate__slow"
				>
					<div class="te-info-card style-2">
						<div class="te-info-card-inner">
							<div
								class="image wow animate__animated animate__slideInLeft animate__slow"
							>
								<img
									src={`${base}/images/about/philosophy.jpg`}
									alt="Our Philosophy"
								/>
							</div>
							<div
								class="te-content-wrapper wow animate__animated animate__slideInRight animate__slow"
							>
								<div class="content about-us-card">
									<p class="desc">
										Our slogan represents our commitment to
										creating value in every transaction. We
										believe in mutual growth, long-term
										partnerships, and transparent business
										practices.
									</p>
									<p class="desc">
										"Serving industries since 2013 with
										global brands, quality products, and
										reliable distribution."
									</p>
									<p class="desc">
										"Your Trusted Partner in Polymers,
										Premium Branded Innerwear Distribution,
										Standard Products and Industrial
										Solutions across GCC, Middle-East &amp;
										Africa."
									</p>
									<p class="desc">
										Dazzle World is directly associated with
										worldwide producers, enabling us to:
									</p>
									<div class="te-list-item-wrapper">
										<div class="te-list-item">
											<div class="myicon">
												<i class="fas fa-check-circle"
												></i>
											</div>
											<span class="text"
												>Maintain high-quality standards</span
											>
										</div>
										<div class="te-list-item">
											<div class="myicon">
												<i class="fas fa-check-circle"
												></i>
											</div>
											<span class="text"
												>Ensure product consistency</span
											>
										</div>
										<div class="te-list-item">
											<div class="myicon">
												<i class="fas fa-check-circle"
												></i>
											</div>
											<span class="text"
												>Provide reliable and timely
												supply</span
											>
										</div>
										<div class="te-list-item">
											<div class="myicon">
												<i class="fas fa-check-circle"
												></i>
											</div>
											<span class="text"
												>Offer competitive pricing</span
											>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- ==================== /PHILOSOPHY ==================== -->

	<!-- ==================== CTA ==================== -->
	<div
		class="subscribe-area style-1 wow animate__animated animate__flipInX animate__slow"
	>
		<div class="circle-drop-shadow"></div>
		<div class="circle-drop-shadow two"></div>
		<div class="container">
			<div class="row">
				<div class="col-xl-6 col-lg-8 offset-xl-3 offset-lg-2">
					<div
						class="te-section-title justify-content-center text-center"
					>
						<div class="te-section-content">
							<div class="short-title-wrapper">
								<span class="short-title">Get in Touch</span>
							</div>
							<h2 class="title">
								Looking for Trusted Solutions?
							</h2>
							<p>
								Whether you need high-quality polymers,
								industrial equipment &amp; consumables, or
								branded innerwear garments, Dazzle World General
								Trading LLC connects you with the right products
								and expertise across the GCC &amp; Africa.
							</p>
						</div>
					</div>
					<div class="te-subscribe-form-widget text-center">
						<div class="btn-wrapper">
							<a
								href={`${base}/contact-us`}
								class="te-theme-btn blue-btn"
							>
								Contact Us <i class="fa fa-solid fa-arrow-right"
								></i>
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- ==================== /CTA ==================== -->

	<!-- ==================== SUSTAINABILITY ==================== -->
	<div class="feature-area style-1">
		<div class="circle-drop-shadow"></div>
		<div class="container">
			<div class="row">
				<div
					class="col-12 wow animate__animated animate__slideInLeft animate__slow"
				>
					<div
						class="te-section-title justify-content-center text-center"
					>
						<div class="te-section-content">
							<div class="short-title-wrapper">
								<span class="short-title">Sustainability</span>
							</div>
							<h2 class="title">
								Committed to Responsible Practices
							</h2>
						</div>
					</div>
				</div>
			</div>
			<div class="row gy-4">
				<div
					class="col-md-12 col-lg-12 feature-card wow animate__animated animate__slideInRight animate__slow"
				>
					<div class="te-info-card style-2">
						<div class="te-info-card-inner">
							<div
								class="image wow animate__animated animate__rotateIn animate__slow"
							>
								<img
									src={`${base}/images/about/choose-2.png`}
									alt="Sustainability"
								/>
							</div>
							<div class="te-content-wrapper">
								<div class="content about-us-card">
									<p class="desc">
										We embrace responsible and sustainable
										business practices by:
									</p>
									<div class="te-list-item-wrapper">
										<div class="te-list-item">
											<div class="myicon">
												<i class="fas fa-check-circle"
												></i>
											</div>
											<span class="text"
												>Partnering with compliant
												manufacturers</span
											>
										</div>
										<div class="te-list-item">
											<div class="myicon">
												<i class="fas fa-check-circle"
												></i>
											</div>
											<span class="text"
												>Promoting efficient resource
												utilization</span
											>
										</div>
										<div class="te-list-item">
											<div class="myicon">
												<i class="fas fa-check-circle"
												></i>
											</div>
											<span class="text"
												>Minimizing operational waste</span
											>
										</div>
										<div class="te-list-item">
											<div class="myicon">
												<i class="fas fa-check-circle"
												></i>
											</div>
											<span class="text"
												>Supporting long-term
												environmental responsibility</span
											>
										</div>
									</div>
									<p class="desc">
										Our focus is sustainable growth that
										benefits businesses, communities, and
										future generations.
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- ==================== /SUSTAINABILITY ==================== -->
</Layout>
