---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout
    title="Dazzle World General Trading LLC – We Trade You Benefit"
    description="Authorized distributor of polymers, resins, branded innerwear garments, perfumes, and industrial solutions across GCC, Middle East & Africa."
>
    <!-- Page Header Start !-->
    <div class="page-breadcrumb-area">
        <div class="page-overlay"></div>
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div
                        class="te-breadcrumb-wrapper wow animate__animated animate__slideInDown animate__slow"
                    >
                        <div class="te-page-heading">
                            <h3 class="te-page-title">Company Profile</h3>
                        </div>
                        <div class="te-breadcrumb-list">
                            <ul>
                                <li><a href={`${base}/`}>Home</a></li>
                                <li class="active">Company Profile</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Page Header End !-->

    <!-- About Area -->
    <div class="about-feature-area">
        <div class="circle-drop-shadow"></div>
        <div class="container">
            <div class="row gy-4 align-items-center">
                <div
                    class="col-lg-6 order-2 order-lg-1 wow animate__animated animate__slideInLeft animate__slow"
                >
                    <div class="about-us-card">
                        <div class="te-section-title">
                            <div class="te-section-content">
                                <div class="short-title-wrapper">
                                    <span class="short-title">About Us</span>
                                </div>
                                <h2 class="title">We Trade You Benefit</h2>
                                <p class="text-justify">
                                    <strong
                                        >M/s Dazzle World General Trading LLC</strong
                                    > is a well-established business conglomerate
                                    established in 2013 with its <strong
                                        >head office in Dubai</strong
                                    > and
                                    <strong
                                        >branch offices in Ajman (UAE) and Doha
                                        (Qatar)</strong
                                    >. The company is managed by highly trained
                                    professionals specializing in supply chain
                                    management, international trading, and
                                    product distribution.
                                </p>
                                <p>Dazzle World operates as:</p>
                                <div class="te-list-item-wrapper">
                                    <div class="te-list-item">
                                        <div class="icon">
                                            <i class="fas fa-check-circle"></i>
                                        </div>
                                        <span class="text"
                                            >Authorized distributor of
                                            international polymer producers.</span
                                        >
                                    </div>
                                    <div class="te-list-item">
                                        <div class="icon">
                                            <i class="fas fa-check-circle"></i>
                                        </div>
                                        <span class="text"
                                            >Sole Distributor of Rupa &amp;
                                            Company Ltd innerwear garments in
                                            the GCC &amp; Africa.</span
                                        >
                                    </div>
                                    <div class="te-list-item">
                                        <div class="icon">
                                            <i class="fas fa-check-circle"></i>
                                        </div>
                                        <span class="text"
                                            >Distributor of industrial products
                                            and consumables for plastic
                                            processing industries.</span
                                        >
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div
                    class="col-lg-6 col-xl-5 offset-xl-1 order-1 order-lg-2 wow animate__animated animate__zoomIn animate__slow"
                >
                    <div class="image-card">
                        <img
                            class="tilt-animate"
                            src={`${base}/images/about/about-card-1.jpg`}
                            alt="About Dazzle World"
                        />
                    </div>
                </div>

                <div
                    class="col-lg-12 order-3 order-lg-3 wow animate__animated animate__slideInLeft animate__slow"
                >
                    <p>
                        With our extensive market knowledge and global sourcing
                        capabilities, we serve customers across Africa, GCC,
                        South Asia, Europe, and the USA, delivering quality,
                        consistency, and competitive pricing.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Why Choose Us -->
    <div class="feature-area style-2">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <div
                        class="te-section-title justify-content-center text-center"
                    >
                        <div
                            class="te-section-content wow animate__animated animate__slideInDown animate__slow"
                        >
                            <div>
                                <span class="short-title">Our Strengths</span>
                            </div>
                            <h2 class="title">
                                Why Choose <span>Dazzleworld</span>
                            </h2>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row gy-4">
                <div class="col-md-6 col-lg-4">
                    <div class="te-testimonial-card style-2">
                        <div class="te-content-wrapper">
                            <div class="content">
                                <h4>Authorized &amp; Sole Distributorships</h4>
                                <p>
                                    We represent exclusive global brands,
                                    ensuring authenticity and quality assurance.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="te-testimonial-card style-2">
                        <div class="te-content-wrapper">
                            <div class="content">
                                <h4>
                                    Direct Association with Global Manufacturers
                                </h4>
                                <p>
                                    We have exclusive partnerships with leading
                                    global manufacturers, ensuring authentic
                                    products and trusted distribution.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="te-testimonial-card style-2">
                        <div class="te-content-wrapper">
                            <div class="content">
                                <h4>Strong Presence in UAE &amp; Qatar</h4>
                                <p>
                                    Established operations and strong market
                                    relationships across key GCC regions
                                    ensuring sustainable growth.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="te-testimonial-card style-2">
                        <div class="te-content-wrapper">
                            <div class="content">
                                <h4>Competitive Pricing Strategy</h4>
                                <p>
                                    Optimized sourcing and cost efficiency to
                                    deliver maximum value.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="te-testimonial-card style-2">
                        <div class="te-content-wrapper">
                            <div class="content">
                                <h4>Experienced &amp; Professional Team</h4>
                                <p>
                                    Skilled industry experts with deep market
                                    knowledge.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="te-testimonial-card style-2">
                        <div class="te-content-wrapper">
                            <div class="content">
                                <h4>
                                    Reliable Logistics &amp; After-Sales Support
                                </h4>
                                <p>
                                    Efficient supply chain and dependable
                                    customer service.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- CTA -->
    <div
        class="subscribe-area style-1 wow animate__animated animate__flipInX animate__slow"
        style="margin-bottom:90px;margin-top:90px;"
    >
        <div class="circle-drop-shadow"></div>
        <div class="circle-drop-shadow two"></div>
        <div class="container">
            <div class="row">
                <div class="col-xl-6 col-lg-8 offset-xl-3 offset-lg-2">
                    <div
                        class="te-section-title justify-content-center text-center"
                    >
                        <div class="te-section-content">
                            <div class="short-title-wrapper">
                                <span class="short-title">Get in Touch</span>
                            </div>
                            <h2 class="title">
                                Looking for Trusted Solutions?
                            </h2>
                            <p>
                                Whether you need high-quality polymers,
                                industrial equipment &amp; consumables, or
                                branded innerwear garments, Dazzle World General
                                Trading LLC connects you with the right products
                                and expertise across the GCC &amp; Africa.
                            </p>
                        </div>
                    </div>
                    <div class="te-subscribe-form-widget text-center">
                        <div class="btn-wrapper">
                            <a
                                href={`${base}/contact-us`}
                                class="te-theme-btn blue-btn"
                            >
                                Contact Us <i class="fa fa-solid fa-arrow-right"
                                ></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>
