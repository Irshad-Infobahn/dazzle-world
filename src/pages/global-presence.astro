    });
</script>-->

    <!-- Page Header Start !-->
    <div class="page-breadcrumb-area">
        <div class="page-overlay"></div>
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div
                        class="te-breadcrumb-wrapper wow animate__animated animate__slideInDown animate__slow"
                    >
                        <div class="te-page-heading">
                            <h3 class="te-page-title">Global Presence</h3>
                        </div>
                        <div class="te-breadcrumb-list">
                            <ul>
                                <li><a href={`${base}/`}>Home</a></li>
                                <li class="active">Global Presence</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Page Header End !-->

    <section class="global-presence-section">
        <div class="container">
            <h3 class="wow animate__animated animate__fadeInUp animate__faster">
                Our Global Presence
            </h3>
            <p class="wow animate__animated animate__fadeInUp animate__fast">
                We have successfully established a strong distribution and
                trading network across:
            </p>
            <ul class="wow animate__animated animate__fadeInUp animate__slow">
                <li>GCC & Middle East</li>
                <li>Africa</li>
                <li>South Asia</li>
                <li>Europe</li>
                <li>United States</li>
            </ul>
            <p class="wow animate__animated animate__fadeInUp animate__slower">
                Our multicultural reach allows us to serve a diverse range of
                industries and companies worldwide.
            </p>

            <!-- Map -->
            <div id="chartdiv"><img src={`${base}/images/map.png`} /></div>
        </div>
    </section>
</Layout>
