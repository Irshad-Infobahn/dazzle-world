        { title: "New York", latitude: 40.7128, longitude: -74.006 },
        { title: "London", latitude: 51.5074, longitude: -0.1278 },
        { title: "Paris", latitude: 48.8566, longitude: 2.3522 },
        { title: "Mumbai", latitude: 19.076, longitude: 72.8777 },
        { title: "Nairobi", latitude: -1.2921, longitude: 36.8219 }
      ];

