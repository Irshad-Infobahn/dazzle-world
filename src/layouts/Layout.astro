---
// Base layout: wraps every page with the <html> shell, header, and footer.
// Props let each page customise the <title> and <meta description>.

interface Props {
    title?: string;
    description?: string;
}

const {
    title = "DAZZLE WORLD GENERAL TRADING LLC",
    description = "Authorized distributor of polymers, resins, branded innerwear garments, perfumes, and industrial solutions across GCC, Middle East & Africa.",
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, ""); // strip trailing slash
